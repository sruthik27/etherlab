#!/bin/bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
TOPOLOGY="collections/stp/scenarios/baseline/topology.clab.yml"
GRAPH_PORT="50081"
GRAPH_URL="http://localhost:${GRAPH_PORT}"
LAB_NAME="$(awk '/^name:/{print $2; exit}' "$ROOT_DIR/$TOPOLOGY")"
NODE_PREFIX="clab-${LAB_NAME}-"

usage() {
  cat <<'EOF'
Usage: bin/cisco-iol-stp [command] [node]

Commands:
  up        Deploy the STP lab (default)
  down      Stop the lab without cleanup
  reset     Destroy the lab and remove generated runtime files
  graph     Start the topology graph on port 50081
  open      Open the topology graph in the browser
  console   Attach to the sw1 or sw2 IOS console
  status    Show lab containers
  help      Show this help

Examples:
  bin/cisco-iol-stp
  bin/cisco-iol-stp console sw1
  bin/cisco-iol-stp console sw2
EOF
}

cmd="${1:-up}"

node_container() {
  case "${1:-}" in
    sw1) echo "${NODE_PREFIX}sw1" ;;
    sw2) echo "${NODE_PREFIX}sw2" ;;
    *)
      echo "Unknown node: ${1:-}" >&2
      exit 1
      ;;
  esac
}

case "$cmd" in
  up)
    exec "$ROOT_DIR/bin/clab" deploy -t "$TOPOLOGY"
    ;;
  down)
    exec "$ROOT_DIR/bin/clab" destroy -t "$TOPOLOGY"
    ;;
  reset)
    exec "$ROOT_DIR/bin/clab" destroy -t "$TOPOLOGY" --cleanup
    ;;
  graph)
    export CLAB_GRAPH_PORT="$GRAPH_PORT"
    exec "$ROOT_DIR/bin/clab" graph -t "$TOPOLOGY"
    ;;
  open)
    exec open "$GRAPH_URL"
    ;;
  console)
    target="${2:-}"
    if [ -z "$target" ]; then
      echo "Usage: bin/cisco-iol-stp console sw1|sw2" >&2
      exit 1
    fi
    node="$(node_container "$target")"
    if ! docker ps --format '{{.Names}}' | grep -qx "$node"; then
      echo "The lab or node is not running. Start it with: bin/cisco-iol-stp" >&2
      exit 1
    fi
    echo "Detach without stopping the switch: Ctrl-p Ctrl-q"
    exec docker attach "$node"
    ;;
  status)
    docker ps -a --format 'table {{.Names}}\t{{.Image}}\t{{.Status}}' | sed -n "1p;/${LAB_NAME}/p"
    ;;
  help|--help|-h)
    usage
    ;;
  *)
    echo "Unknown command: $cmd" >&2
    echo >&2
    usage >&2
    exit 1
    ;;
esac
